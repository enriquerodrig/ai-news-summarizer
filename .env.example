# Required Environment Variables
# HuggingFace API token for accessing summarization models
HUGGINGFACE_TOKEN=your_huggingface_token_here

# MCP Server URL for news data retrieval (use RSS feed URLs or MCP RSS server)
# Examples:
# - Direct RSS feed: https://news.ycombinator.com/rss
# - Multiple feeds (comma-separated): https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml
# - MCP RSS Aggregator: http://localhost:3000 (if running mcp-rss-aggregator locally)
MCP_SERVER_URL=https://news.ycombinator.com/rss,https://techcrunch.com/feed/,https://www.theverge.com/rss/index.xml,https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml

# Optional Environment Variables (with defaults)
# Port for the web service (default: 8080)
PORT=8080

# Cache TTL in minutes (default: 30)
CACHE_TTL_MINUTES=30

# News refresh interval in minutes (default: 30)
NEWS_REFRESH_MINUTES=30

# Maximum concurrent summarization tasks (default: 50)
MAX_CONCURRENT_SUMMARIES=50

# Memory limit in MB (default: 512)
MEMORY_LIMIT_MB=512

# Log level: INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO
